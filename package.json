{
  "name": "nicons",
  "version": "1.4.1",
  "description": "Customize icons with bundled Phosphor icon assets.",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "prebuild": "node scripts/generate-bundled-phosphor.mjs",
    "generate:icons": "node scripts/generate-bundled-phosphor.mjs --force",
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "lint": "eslint \"src/**/*.ts\""
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "icons",
    "phosphor"
  ],
  "license": "MIT",
  "devDependencies": {
    "@codemirror/language": "^6.12.3",
    "@codemirror/view": "^6.38.6",
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.0.0",
    "esbuild": "^0.25.5",
    "eslint": "^9.39.4",
    "eslint-plugin-obsidianmd": "^0.4.1",
    "globals": "^17.7.0",
    "jiti": "^2.7.0",
    "obsidian": "^1.8.7",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.63.0"
  }
}
