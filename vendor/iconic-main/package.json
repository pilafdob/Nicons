		"@types/node": "^25.5.0",
		"@typescript-eslint/eslint-plugin": "8.58.0",
		"@typescript-eslint/parser": "8.58.0",
		"builtin-modules": "^5.0.0",
		"esbuild": "^0.27.4",
		"obsidian": "^1.12.3",
		"tslib": "2.8.1",
		"typescript": "6.0.2"
